# This library is a rewrite of the original `backuplib` written by Martin J. McGowan III, and published [here] and [here on Github].
# This rewritten library updates the basic TOBYWEN workflow described [here]. It also is part of a Backup/Version/Release workflow described [here].
# some functions in this library depend on `zshutilib`
# 2026-03-01: command-line library function
backup () {
    echo ENTRY $# "$@"
    case "${1:-__NADA__}" in
	(__NADA__) echo "nada: backup_help" ;;
	("help"|"-h") echo "backup_help" ;;
	("init") backup_init ;;
	("status") backup_status ;;
	("diff") backup_diff $2 ;;
	("needed") backup_needed $2 ;;
	("prune") backup_prune $2 ;;
	(*) backup_ "$@" ;;
    esac
}

backup_ () {
    : ~ one or more files down the $BACKUP_DIRECTORY/.bak/.bak/... stack
    : date: 2023-09-20
    : date: 2026-01-23: specify BACKUP_DIRECTORY
    debug $# "$@"
    if confirm "backup to '$BACKUP_DIRECTORY'"
    then
	foreach_ backup_one "$@"
    else
	echo "run 'backup_init [backup_directory]' before running 'backup'"
    fi
}

backup_diff () {
	: diff a file with the latest copy in BACKUP_DIRECTORY
	: uses: diff
	: date: 2026-03-01
	(( $# )) || { echo "Usage: backup_diff filename"; return 1 }
	local backdir=${BACKUP_DIRECTORY:-.bak}
	if [[ ! -e "$1" ]]; then
	    echo "ERROR: file $backdir/$1 does not exist"
	    return 1
	fi
	diff --color="auto" "$backdir/$1" "$1"
}

backup_files () 
{ 
    : list only immediate backed up files
    : lib: zshutilib
    : date: 2023-10-21;
    : date: 2026-01-27: BACKUP_DIRECTORY
    echo "First level backed up files: "
    indir "${BACKUP_DIRECTORY:-.bak}" namedfiles
}

backup_here () {
    : recursively move backups down the stack
    : clearing the way for their replacement at the top
    : date: 2023-09-11
    : date: 2024-04-29
    : date: 2026-01-27: Gemini generated subshell refactoring
    debug ENTRY $# "$@"
    local filename="$1" 
    local target_dir="${2:-$BACKUP_DIRECTORY}"
    debug ENTRY TARGETDIR "$target_dir"
    local origin_pwd="${3:-$PWD}" 
    local mode
    [[ -d "$target_dir" ]] || mkdir -p "$target_dir"
    if [[ "$origin_pwd" == "$PWD" ]]
    then
	if cmp -s "$filename" "$target_dir/$filename" 2> /dev/null
	then
	    printf '%s unchanged, skipping backup\n' "$filename"
	    return 0
	fi
	mode=$(classic_mode "$filename") 
    fi
    : recursive logic: if the slot taken, push the old one deeper
    : debug targetdir "$target_dir"
    if [[ -f "$target_dir/$filename" ]]
    then
	(
	    cd "$target_dir" || exit 1
	    : debug TARGETDIR "$target_dir"
	    backup_here "$filename" ".bak" "$origin_pwd"
	)
    fi
    : move the file into the now-vacant slot
    mv "$filename" "$target_dir/$filename"
    : restore the file at the origin if this was the top-level call
    : debug ORIGINPWD "$origin_pwd"
    if [[ "$origin_pwd" == "$PWD" ]]
    then
	cp "$target_dir/$filename" "$filename"
	timestamp "$target_dir/$filename" "$filename"
	chmod "$mode" "$filename"
    fi
}
backup_init () 
{
    : establish {BACKUP,VERSION,RELEASE}_DIRECTORY ENV vars;
    : date: 2023-09-18;
    : date: 2026-01-20: specify working dir or use cwd
    : lib: zshutilib
    debug $# $@
    if [[ $# -gt 1 ]]; then
	usage "[backupdir] - provide directory path for backup, or use cwd"
	return
    fi
    setenv BACKUP_DIRECTORY ${1:-.}/.bak > /dev/null
    setenv VERSION_DIRECTORY ${1:-.}/.ver > /dev/null
    setenv RELEASE_DIRECTORY ${1:-.}/.rel > /dev/null
}
backup_one () 
{
    # 2026-01-01: TODO: revisit the non-local directory operation
    : for a single file in possible non-local directory;
    : date: 2023-09-11;
    debug ENTRY $PWD $@;
    : date: 2024-04-29;
    local file=${1:-/dev/null};
    report_notfile $file && return 1
    local file=$(basename $file);
    local dir=$(dirname $1);
    quiet pushd $dir;
    : debug PUSHD $(dirs);
    : pause;
    backup_here $file;
    quiet popd;
    : debug POPD $(dirs);
    : pause
}
backup_onlyfiles () 
{ 
    : candidate backup files, including DOT files;
    : lib: zshutilib
    : date: 2026-01-01: use array to handle shell expansion
    local files=( * .* )
    foreach_ name_existing "${files[@]}"
}
backup_outdated () 
{ 
    : files in BACKUP_DIRECTORY tree not in cwd;
    : uses: comm
    comm -13 <(backup_onlyfiles) <(indir ${BACKUP_DIRECTORY:-.bak} backup_onlyfiles)
}

backup_needed () {
    : files in cwd not in $BACKUP_DIRECTORY tree
    : date: 2026-01-27
    cmp -s "$1" "${BACKUP_DIRECTORY:-.bak}"/"$1" || echo "$1"
}

backup_prune () {
    : prune BACKUP_DIRECTORY files not linked to a VERSION_DIRECTORY file
    : uses: basename, find, rm, sort
    : date: 2026-01-24 -- include dry-run option
    : debug ENTRY $# "$@" $(pwd)
    prunefile () {
	while IFS= read -r file; do
	    if [[ "$1" == "-d" ]]; then
		printf 'dry-run: prune (i.e., rm -v) %s\n' "$file"
	    else
		rm -v "$file"
	    fi
	done
    }
    for f in $(find ${VERSION_DIRECTORY:-.ver} -type f)
    do
	: debug echo $f
	find ${BACKUP_DIRECTORY:-.}/.bak/.bak -name $(basename $f) -links 1
    done | sort -u | prunefile "$1"
    : prune unversioned files older than the last 2 backups
    find ${BACKUP_DIRECTORY:-.}/.bak/.bak/.bak -type f -links 1 | prunefile "$1"
}

backup_status () {
    : show backup and version info of files in BACKUP_DIRECTORY
    : uses: tree
    : lib: zshutilib
    : date: 2026-01-21
    : debug ENTRY "$*"
    echo "files in cwd not backed up in $(dirname $BACKUP_DIRECTORY):"
    foreach_ backup_needed *lib
    if confirm "Show all version and backup files"; then
	echo "\nversion files:"
	version_status
	tree -a ${VERSION_DIRECTORY:-.ver}
	echo "\nbackup tree:"
	tree -a ${BACKUP_DIRECTORY:-.bak}
    fi
}
